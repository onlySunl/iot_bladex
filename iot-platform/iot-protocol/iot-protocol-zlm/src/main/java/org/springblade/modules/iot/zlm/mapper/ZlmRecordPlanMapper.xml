<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.springblade.modules.iot.zlm.mapper.ZlmRecordPlanMapper">
    
    <resultMap type="ZlmRecordPlan" id="ZlmRecordPlanResult">
        <result property="id"    column="id"    />
        <result property="snap"    column="snap"    />
        <result property="name"    column="name"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectZlmRecordPlanVo">
        select id, snap, name, status, create_time, update_time from zlm_record_plan
    </sql>

    <select id="selectZlmRecordPlanList" parameterType="ZlmRecordPlan" resultMap="ZlmRecordPlanResult">
        <include refid="selectZlmRecordPlanVo"/>
        <where>  
            <if test="snap != null "> and snap = #{snap}</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectZlmRecordPlanById" parameterType="Long" resultMap="ZlmRecordPlanResult">
        <include refid="selectZlmRecordPlanVo"/>
        where id = #{id}
    </select>

    <select id="queryRecordIng" resultType="java.lang.Long">
        SELECT d.id
        FROM qs_device d
                 LEFT JOIN zlm_record_plan_item rpi ON rpi.plan_id = d.record_plan_id
                 LEFT JOIN zlm_record_plan rp ON rp.id = rpi.plan_id AND rp.status = 0
        WHERE rpi.week_day = #{week}
          AND rpi.start &lt;= #{index}
          AND rpi.stop &gt;= #{index}
          AND rp.id IS NOT NULL
          AND d.status = 'ENABLE'
        GROUP BY d.id
    </select>

    <insert id="insertZlmRecordPlan" parameterType="ZlmRecordPlan" useGeneratedKeys="true" keyProperty="id">
        insert into zlm_record_plan
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="snap != null">snap,</if>
            <if test="name != null">name,</if>
            <if test="status != null">status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="snap != null">#{snap},</if>
            <if test="name != null">#{name},</if>
            <if test="status != null">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateZlmRecordPlan" parameterType="ZlmRecordPlan">
        update zlm_record_plan
        <trim prefix="SET" suffixOverrides=",">
            <if test="snap != null">snap = #{snap},</if>
            <if test="name != null">name = #{name},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteZlmRecordPlanByIds" parameterType="String">
        delete from zlm_record_plan where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>